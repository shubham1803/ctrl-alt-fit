# Gemini API Key
# Get your key from: https://aistudio.google.com/app/apikey
# Add this in Vercel Dashboard → Settings → Environment Variables
GEMINI_API_KEY=your-gemini-key-here

# Expo native/web frontend API base URL
# For iOS/Android builds set this to your deployed backend URL.
# Example: EXPO_PUBLIC_API_BASE_URL=https://ctrl-alt-fit.vercel.app
EXPO_PUBLIC_API_BASE_URL=
