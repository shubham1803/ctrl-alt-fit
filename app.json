{
  "expo": {
    "name": "CTRL-ALT-FIT",
    "slug": "ctrl-alt-fit",
    "scheme": "ctrlaltfit",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1220"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ctrlaltfit.app",
      "infoPlist": {
        "NSCameraUsageDescription": "CTRL-ALT-FIT uses camera to scan your meals.",
        "NSPhotoLibraryUsageDescription": "CTRL-ALT-FIT uses your photos to analyze meals.",
        "NSMicrophoneUsageDescription": "CTRL-ALT-FIT uses microphone for voice notes in group chat."
      }
    },
    "android": {
      "package": "com.ctrlaltfit.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b1220"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    }
  }
}
